# Agent backend operator environment (optional)

# Managed hosting control plane (M15) — droplet /opt/atom/.env
# ATOM_FLEET_MODE=docker
# ATOM_AGENT_IMAGE=atom-agent:latest
# ATOM_CONTROL_PLANE_DATA_DIR=/data
# ATOM_FLEET_PUBLIC_URL_TEMPLATE=https://{port}.agents.atom.qwixl.com
# ATOM_SHELL_ORIGINS=https://atom.qwixl.com
# ATOM_PROVISION_SECRET=
# NODE_ENV=production

# Supabase — control plane only (NEVER in Vercel / browser)
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# Supabase — shell-atom Vercel project only (publishable key, safe in browser)
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=
