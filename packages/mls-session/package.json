{
  "name": "@qwixl/mls-session",
  "version": "0.1.0",
  "description": "RFC 9420 MLS pair sessions for Atom agent backends (1:1 E2E over A2A).",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
