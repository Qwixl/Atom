{
  "name": "@qwixl/registry-tools",
  "version": "0.2.0",
  "description": "CLI to hash, verify, and publish Atom module registry indexes.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "bin": {
    "atom-registry": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Qwixl/Atom.git",
    "directory": "packages/registry-tools"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "scaffold": "node dist/cli.js scaffold",
    "verify": "node dist/cli.js verify",
    "test": "vitest run",
    "publish-module": "node dist/cli.js publish",
    "publish-all": "node dist/cli.js publish-all"
  },
  "dependencies": {
    "@qwixl/shell-core": "workspace:*",
    "sigstore": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  }
}
