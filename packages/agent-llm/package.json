{
  "name": "@qwixl/agent-llm",
  "version": "0.1.5",
  "description": "LLM-backed AgentSession for the Atom shell: any OpenAI-compatible chat endpoint composes surfaces from the shell's catalog.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Qwixl/Atom.git",
    "directory": "packages/agent-llm"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "eval:tools": "tsx evals/runToolsEval.ts",
    "admin:model-behavior": "tsx evals/adminModelBehavior.ts"
  },
  "dependencies": {
    "@qwixl/shell-core": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  }
}
