{
  "name": "@qwixl/ag-ui-adapter",
  "version": "0.1.1",
  "description": "AG-UI wire transport adapter for Atom shell-core AgentSession.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Qwixl/Atom.git",
    "directory": "packages/ag-ui-adapter"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.57",
    "@qwixl/a2ui-adapter": "workspace:*",
    "@qwixl/shell-core": "workspace:*",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
