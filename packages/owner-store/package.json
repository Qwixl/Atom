{
  "name": "@qwixl/owner-store",
  "version": "0.1.1",
  "description": "Owner-controlled profile/memory store for the Atom shell: portable records, guarded categories, scoped context slices for agent disclosure.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Qwixl/Atom.git",
    "directory": "packages/owner-store"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@qwixl/shell-core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
