{
  "name": "atom",
  "private": true,
  "version": "0.1.0",
  "devDependencies": {
    "@changesets/cli": "^2.29.5"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @atom/shell-app dev",
    "dev:embed": "pnpm --filter @atom/embed-demo dev",
    "dev:ag-ui": "pnpm --filter @atom/ag-ui-server dev",
    "dev:registry": "pnpm --filter @atom/registry-host dev",
    "registry:verify": "pnpm --filter @atom/registry-tools verify",
    "registry:publish": "pnpm --filter @atom/registry-tools publish-module",
    "build:packages": "pnpm --filter @atom/shell-core --filter @atom/a2ui-adapter --filter @atom/ag-ui-adapter --filter @atom/owner-store --filter @atom/renderer-web --filter @atom/registry-tools build",
    "build:apps": "pnpm --filter @atom/shell-app --filter @atom/registry-host build",
    "build": "pnpm build:packages && pnpm build:apps",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @atom/shell-core test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build:packages && changeset publish"
  }
}
