{
  "name": "atom",
  "private": true,
  "version": "0.1.0",
  "devDependencies": {
    "@changesets/cli": "^2.29.5"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node scripts/dev-browser.mjs",
    "dev:shell-only": "pnpm --filter @qwixl/shell-app dev",
    "dev:embed": "pnpm --filter @qwixl/embed-demo dev",
    "dev:docs": "pnpm --filter @qwixl/docs-site dev",
    "dev:control-plane": "pnpm --filter @qwixl/control-plane dev",
    "dev:hosting": "node scripts/dev-hosting.mjs",
    "dev:ag-ui": "pnpm --filter @qwixl/ag-ui-server dev",
    "dev:agent-only": "pnpm --filter @qwixl/business-index build && pnpm --filter @qwixl/agent-backend dev",
    "dev:a2a": "pnpm dev:agent-only",
    "atom": "pnpm --filter @qwixl/atom-cli dev",
    "dev:demo": "node scripts/dev-demo.mjs",
    "dev:demo-peer": "pnpm --filter @qwixl/agent-backend dev:demo-peer",
    "dev:coffee-shop": "pnpm --filter @qwixl/agent-backend dev:coffee-shop",
    "start:agent": "pnpm --filter @qwixl/agent-backend start",
    "docker:agent": "docker compose up atom-agent --build",
    "docker:demo-peer": "docker compose up demo-peer-agent --build",
    "docker:hosting": "docker compose up demo-peer-agent control-plane --build",
    "registry:verify": "pnpm --filter @qwixl/registry-tools verify",
    "registry:publish": "pnpm --filter @qwixl/registry-tools publish-module",
    "registry:publish-all": "pnpm --filter @qwixl/registry-tools publish-all",
    "registry:scaffold": "pnpm --filter @qwixl/registry-tools scaffold",
    "build:packages": "pnpm --filter @qwixl/shell-core --filter @qwixl/a2ui-adapter --filter @qwixl/ag-ui-adapter --filter @qwixl/owner-store --filter @qwixl/connector-custody --filter @qwixl/renderer-web --filter @qwixl/registry-tools --filter @qwixl/protocol --filter @qwixl/mls-session --filter @qwixl/a2a-transport --filter @qwixl/agent-llm --filter @qwixl/agent-backend --filter @qwixl/business-index --filter @qwixl/atom-cli build",
    "build:apps": "pnpm --filter @qwixl/shell-app --filter @qwixl/registry-host --filter @qwixl/docs-site build",
    "build": "pnpm build:packages && pnpm build:apps",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @qwixl/shell-core --filter @qwixl/protocol --filter @qwixl/mls-session --filter @qwixl/a2a-transport --filter @qwixl/owner-store --filter @qwixl/business-index test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build:packages && changeset publish"
  }
}
