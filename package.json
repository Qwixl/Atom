{
  "name": "atom",
  "private": true,
  "version": "0.1.0",
  "devDependencies": {
    "@changesets/cli": "^2.29.5"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @qwixl/shell-app dev",
    "dev:embed": "pnpm --filter @qwixl/embed-demo dev",
    "dev:ag-ui": "pnpm --filter @qwixl/ag-ui-server dev",
    "dev:a2a": "pnpm --filter @qwixl/agent-backend dev",
    "start:agent": "pnpm --filter @qwixl/agent-backend start",
    "docker:agent": "docker compose up atom-agent --build",
    "registry:verify": "pnpm --filter @qwixl/registry-tools verify",
    "registry:publish": "pnpm --filter @qwixl/registry-tools publish-module",
    "registry:scaffold": "pnpm --filter @qwixl/registry-tools scaffold",
    "build:packages": "pnpm --filter @qwixl/shell-core --filter @qwixl/a2ui-adapter --filter @qwixl/ag-ui-adapter --filter @qwixl/owner-store --filter @qwixl/renderer-web --filter @qwixl/registry-tools --filter @qwixl/protocol --filter @qwixl/mls-session --filter @qwixl/a2a-transport --filter @qwixl/agent-llm --filter @qwixl/agent-backend build",
    "build:apps": "pnpm --filter @qwixl/shell-app --filter @qwixl/registry-host build",
    "build": "pnpm build:packages && pnpm build:apps",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @qwixl/shell-core --filter @qwixl/protocol --filter @qwixl/mls-session --filter @qwixl/a2a-transport test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build:packages && changeset publish"
  }
}
